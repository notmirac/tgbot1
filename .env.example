# ─────────────────────────────────────────
#  Пример файла переменных окружения
#  Скопируй этот файл в .env и заполни
# ─────────────────────────────────────────

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# API-ключ OpenAI (или совместимого сервиса)
OPENAI_API_KEY=your_openai_api_key_here

# Базовый URL API (оставь пустым для официального OpenAI)
# Для совместимых API (например, OpenRouter) укажи их URL:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Модель для обычного чата
CHAT_MODEL=gpt-4o-mini

# Модель для чата 18+
CHAT_18_MODEL=gpt-4o-mini

# ID фотографий 18+ (file_id из Telegram или публичный URL)
# Через запятую без пробелов
PHOTO_18_IDS=https://example.com/photo1.jpg,https://example.com/photo2.jpg
